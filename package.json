{
  "name": "api-rate-limiter",
  "version": "0.1.0",
  "description": "A production-style TypeScript API rate limiter with pluggable algorithms, storage adapters, and middleware integrations.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "import": "./dist/redis.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "bench": "tsc -p tsconfig.bench.json && node .bench/benchmarks/limiter.bench.js",
    "bench:http": "tsc -p tsconfig.bench.json && node .bench/benchmarks/http-autocannon.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "rate-limiter",
    "api",
    "middleware",
    "typescript",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "autocannon": "^8.0.0",
    "express": "^5.2.1",
    "redis": "^5.12.1",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "redis": "^5.12.1"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  }
}
